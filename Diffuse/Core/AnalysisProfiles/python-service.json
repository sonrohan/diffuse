{
  "version": 1,
  "id": "python-service",
  "displayName": "Python service",
  "extends": ["generic"],
  "fileClassifications": [
    {
      "classification": "test",
      "paths": ["**/test_*.py", "**/*_test.py", "**/tests/**"]
    },
    {
      "classification": "config",
      "paths": ["pyproject.toml", "requirements*.txt", "setup.py", "setup.cfg", "tox.ini", "ruff.toml"]
    }
  ],
  "buckets": [
    {
      "id": "api-contract",
      "type": "api-contract",
      "title": "API and route changes",
      "paths": ["**/api/**", "**/routes/**", "**/views/**", "**/handlers/**"]
    },
    {
      "id": "data",
      "type": "data",
      "title": "Data and persistence changes",
      "paths": ["**/models/**", "**/migrations/**", "**/repositories/**", "**/db/**"]
    }
  ],
  "rules": {
    "schemaSync": {
      "enabled": true,
      "migrationPaths": ["**/migrations/**", "**/*.sql"],
      "schemaPaths": ["**/models/**", "**/db/**"],
      "message": "Database migration detected, but no configured schema or model changes were found in this PR."
    }
  },
  "riskScoring": {
    "apiPaths": ["**/api/**", "**/routes/**", "**/views/**", "**/handlers/**"],
    "sensitivePaths": ["**/*auth*", "**/*payment*", "**/*security*", "**/*permission*"]
  }
}

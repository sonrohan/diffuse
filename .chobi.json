        "**/Models.swift",
        "**/SwiftDataEntities.swift"
      ],
      "title" : "Data model and persistence changes",
      "type" : "data"
    },
    {
      "findingCategories" : [
        "architecture"
      ],
      "id" : "api-contract",
      "title" : "API and contract surface",
      "type" : "api-contract"
    },
    {
      "id" : "rust-core",
      "paths" : [
        "chobi-core/**/*.rs"
      ],
      "title" : "Rust core analysis engine",
      "type" : "behavior"
    },
    {
      "classifications" : [
        "test"
      ],
      "id" : "tests",
      "title" : "Tests and coverage",
      "type" : "tests"
    },
    {
      "classifications" : [
        "generated",
        "boilerplate"
      ],
      "id" : "generated",
      "title" : "Generated and boilerplate changes",

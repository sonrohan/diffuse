{
  "version": 1,
  "id": "generic",
  "displayName": "Generic repository",
  "fileClassifications": [
    {
      "classification": "generated",
      "paths": [
        "**/package-lock.json",
        "**/yarn.lock",
        "**/pnpm-lock.yaml",
        "**/Gemfile.lock",
        "**/Cargo.lock",
        "**/go.sum",
        "**/dist/**",
        "**/build/**",
        "**/target/**",
        "**/.next/**",
        "**/coverage/**",
        "**/generated/**",
        "**/*.generated.*",
        "**/*.min.js",
        "**/*.map"
      ]
    },
    {
      "classification": "test",
      "paths": [
        "**/*.test.*",
        "**/*.spec.*",
        "**/*_test.*",
        "**/*Test.*",
        "**/*Tests.*",
        "**/*Spec.*",
        "**/__tests__/**",
        "**/tests/**",
        "**/test/**",
        "**/spec/**",
        "**/specs/**"
      ]
    },
    {
      "classification": "config",
      "paths": [
        ".env*",
        ".*rc",
        ".*rc.*",
        "Dockerfile",
        "**/Dockerfile",
        "**/docker-compose*.yml",
        "**/*.json",
        "**/*.yaml",
        "**/*.yml",
        "**/*.toml",
        "**/*.properties",
        "**/*.config.*",
        "**/*config.*"
      ]
    },
    {
      "classification": "documentation",
      "paths": [
        "**/*.md",
        "**/*.txt",
        "**/*.rst",
        "**/docs/**",
        "**/documentation/**"
      ]
    },
    {
      "classification": "boilerplate",
      "paths": [
        "**/*.d.ts",
        "**/vendor/**",
        "**/third_party/**",
        "**/fixtures/**",
        "**/snapshots/**"
      ]
    }
  ],
  "buckets": [
    {
      "id": "auth-security",
      "type": "auth-security",
      "title": "Auth and security-sensitive changes",
      "findingCategories": ["security"],
      "symbolSemanticAreas": ["security_authentication", "security_cryptography"]
    },
    {
      "id": "data",
      "type": "data",
      "title": "Data and persistence changes",
      "symbolSemanticAreas": ["data_deletion"]
    },
    {
      "id": "api-contract",
      "type": "api-contract",
      "title": "API and contract surface",
      "findingCategories": ["architecture"]
    },
    {
      "id": "tests",
      "type": "tests",
      "title": "Tests and coverage",
      "classifications": ["test"]
    },
    {
      "id": "generated",
      "type": "generated",
      "title": "Generated and boilerplate changes",
      "classifications": ["generated", "boilerplate"]
    },
    {
      "id": "docs",
      "type": "docs",
      "title": "Documentation changes",
      "classifications": ["documentation"]
    },
    {
      "id": "build-config",
      "type": "build-config",
      "title": "Build, dependency, and config changes",
      "classifications": ["config"]
    },
    {
      "id": "behavior",
      "type": "behavior",
      "title": "Production behavior changes"
    }
  ],
  "symbolGroups": [
    {"id": "security_authentication", "label": "Authentication", "icon": "lock.shield", "semanticAreas": ["security_authentication"]},
    {"id": "security_cryptography", "label": "Cryptography", "icon": "key", "semanticAreas": ["security_cryptography"]},
    {"id": "payment", "label": "Payment", "icon": "creditcard", "semanticAreas": ["payment"]},
    {"id": "data_deletion", "label": "Data Deletion", "icon": "trash", "semanticAreas": ["data_deletion"]},
    {"id": "tests", "label": "Tests", "icon": "checkmark.seal", "metadataEquals": {"is_test": "true"}},
    {"id": "general", "label": "Logic Changes", "icon": "cpu", "fallback": true}
  ],
  "rules": {
    "missingTests": {
      "enabled": true,
      "minimumAdditions": 10,
      "sourceClassifications": ["source"],
      "testClassifications": ["test"],
      "message": "Significant logic change ({additions} additions) without any matching test file additions or updates in this PR."
    },
    "schemaSync": {
      "enabled": false,
      "migrationPaths": [],
      "schemaPaths": [],
      "message": "Schema migration detected without a corresponding configured schema or model change."
    },
    "importBoundaries": [],
    "semanticAreaFindings": [
      {
        "id": "security/auth-ast",
        "semanticArea": "security_authentication",
        "severity": "high",
        "category": "security",
        "message": "Auth symbol '{symbol}' modified. High regression risk - changes to authentication logic must be reviewed for correctness and side effects."
      },
      {
        "id": "security/crypto-ast",
        "semanticArea": "security_cryptography",
        "severity": "high",
        "category": "security",
        "message": "Cryptographic symbol '{symbol}' modified. Encryption/signing changes carry high security risk."
      },
      {
        "id": "security/payment-ast",
        "semanticArea": "payment",
        "severity": "medium",
        "category": "security",
        "message": "Payment symbol '{symbol}' modified. Validate billing flow correctness and test against edge cases."
      }
    ],
    "contractFindings": [
      {
        "id": "contract/signature-changed",
        "metadataEquals": {"contract_signature_changed": "true"},
        "severity": "medium",
        "category": "architecture",
        "message": "Public API contract change: '{symbol}' signature modified. Verify all callers are compatible."
      },
      {
        "id": "contract/return-type-changed",
        "metadataEquals": {"contract_return_type_changed": "true"},
        "severity": "medium",
        "category": "architecture",
        "message": "Public API contract change: '{symbol}' return type changed. Verify callers and serialization boundaries."
      },
      {
        "id": "contract/new-public",
        "metadataEquals": {"contract_is_new_public": "true"},
        "severity": "low",
        "category": "architecture",
        "message": "New public symbol '{symbol}' added to the API surface."
      }
    ],
    "symbolCoverage": {
      "enabled": true,
      "riskMetadataPrefixes": ["contract_"],
      "riskMetadataSuffixes": ["_added"],
      "riskMetadataEquals": {"is_critical": "true"},
      "message": "Risky production symbol '{symbol}' changed without a related test symbol update."
    }
  },
  "semanticHighlights": [
    {
      "id": "security_authentication",
      "semanticArea": "security_authentication",
      "severity": "high",
      "category": "security",
      "title": "Auth symbol '{symbol}' modified",
      "evidence": "AST-verified: '{symbol}' ({semanticType}) is an authentication entry point."
    },
    {
      "id": "security_cryptography",
      "semanticArea": "security_cryptography",
      "severity": "high",
      "category": "security",
      "title": "Cryptographic symbol '{symbol}' modified",
      "evidence": "AST-verified: '{symbol}' ({semanticType}) handles encryption or signing."
    },
    {
      "id": "payment",
      "semanticArea": "payment",
      "severity": "medium",
      "category": "contract",
      "title": "Payment symbol '{symbol}' modified",
      "evidence": "AST-verified: '{symbol}' ({semanticType}) is in the payment flow."
    },
    {
      "id": "data_deletion",
      "semanticArea": "data_deletion",
      "severity": "medium",
      "category": "data",
      "title": "Deletion symbol '{symbol}' modified",
      "evidence": "AST-verified: '{symbol}' ({semanticType}) performs data deletion."
    },
    {
      "id": "network_call_added",
      "metadataEquals": {"network_call_added": "true"},
      "severity": "medium",
      "category": "coupling",
      "title": "'{symbol}' adds a network call",
      "evidence": "AST comparison: '{symbol}' introduces a network request. Verify error handling, timeouts, and retry logic."
    },
    {
      "id": "persistence_write_added",
      "metadataEquals": {"persistence_write_added": "true"},
      "severity": "medium",
      "category": "data",
      "title": "'{symbol}' adds a persistent write",
      "evidence": "AST comparison: '{symbol}' introduces a persistence write. Confirm data compatibility and rollback behavior."
    },
    {
      "id": "auth_check_added",
      "metadataEquals": {"auth_check_added": "true"},
      "severity": "high",
      "category": "security",
      "title": "'{symbol}' adds an authorization check",
      "evidence": "AST comparison: authorization guard introduced in '{symbol}'. Verify the check is sufficient and cannot be bypassed."
    },
    {
      "id": "deletion_added",
      "metadataEquals": {"deletion_added": "true"},
      "severity": "medium",
      "category": "data",
      "title": "'{symbol}' adds a deletion or destructive operation",
      "evidence": "AST comparison: destructive operation introduced in '{symbol}'. Confirm scope and cascade handling."
    },
    {
      "id": "async_behavior_added",
      "metadataEquals": {"async_behavior_added": "true"},
      "severity": "info",
      "category": "runtime",
      "title": "'{symbol}' adds async/concurrency behavior",
      "evidence": "AST comparison: async or concurrency patterns introduced in '{symbol}'. Verify scheduling, cancellation, and error propagation."
    },
    {
      "id": "new_symbol",
      "metadataEquals": {"symbol_is_new": "true"},
      "severity": "low",
      "category": "review-load",
      "title": "New symbol '{symbol}' added",
      "evidence": "AST extracted a new {semanticType}. Review the implementation and callers introduced with this change."
    },
    {
      "id": "control_flow_added",
      "metadataEquals": {"control_flow_added": "true"},
      "severity": "low",
      "category": "runtime",
      "title": "'{symbol}' adds branching or iteration",
      "evidence": "AST comparison: '{symbol}' introduces control flow. Check edge cases and unreachable states."
    },
    {
      "id": "error_handling_added",
      "metadataEquals": {"error_handling_added": "true"},
      "severity": "low",
      "category": "runtime",
      "title": "'{symbol}' adds error handling",
      "evidence": "AST comparison: '{symbol}' introduces error handling. Verify fallback behavior and swallowed failures."
    },
    {
      "id": "logging_added",
      "metadataEquals": {"logging_added": "true"},
      "severity": "info",
      "category": "review-load",
      "title": "'{symbol}' adds logging or telemetry",
      "evidence": "AST comparison: '{symbol}' introduces logging or telemetry. Check privacy and signal quality."
    }
  ],
  "fileHighlights": [],
  "riskScoring": {
    "generatedOnlyDelta": -40,
    "productionChangeDelta": 10,
    "apiPathDelta": 20,
    "sensitivePathDelta": 30,
    "missingTestsDelta": 20,
    "architectureFindingDelta": 20,
    "highFanInDelta": 10,
    "contractDelta": 10,
    "behaviorAddedDelta": 10,
    "testChangeDelta": -15,
    "apiPaths": [],
    "sensitivePaths": []
  }
}

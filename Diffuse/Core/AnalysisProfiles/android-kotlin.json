{
  "version": 1,
  "id": "android-kotlin",
  "displayName": "Android / Kotlin",
  "extends": ["generic"],
  "fileClassifications": [
    {
      "classification": "test",
      "paths": ["**/src/test/**", "**/src/androidTest/**", "**/*Test.kt", "**/*Tests.kt", "**/*Spec.kt"]
    },
    {
      "classification": "config",
      "paths": ["settings.gradle", "settings.gradle.kts", "build.gradle", "build.gradle.kts", "**/*.gradle", "**/*.gradle.kts", "**/gradle/**"]
    },
    {
      "classification": "generated",
      "paths": ["**/build/**", "**/generated/**"]
    }
  ],
  "buckets": [
    {
      "id": "ui",
      "type": "ui",
      "title": "User-facing UI changes",
      "paths": ["**/ui/**", "**/*Screen.kt", "**/*View.kt", "**/compose/**"]
    },
    {
      "id": "behavior",
      "type": "behavior",
      "title": "State and app behavior changes",
      "paths": ["**/*ViewModel.kt", "**/*Reducer.kt", "**/*UseCase.kt", "**/domain/**"]
    },
    {
      "id": "data",
      "type": "data",
      "title": "Data model and persistence changes",
      "paths": ["**/data/**", "**/database/**", "**/*Dao.kt", "**/*Entity.kt", "**/*Repository.kt"]
    }
  ],
  "rules": {
    "importBoundaries": [
      {
        "id": "architecture/android-ui-import-boundary",
        "sourcePaths": ["**/ui/**", "**/*Screen.kt", "**/compose/**"],
        "forbiddenImports": ["*database*", "*repository*", "*room*", "*dao*", "*datastore*"],
        "severity": "medium",
        "category": "architecture",
        "message": "UI symbol '{symbol}' imports lower-level infrastructure. Keep presentation code behind configured app boundaries."
      }
    ]
  },
  "fileHighlights": [
    {
      "id": "android-large-visible-surface",
      "classifications": ["source"],
      "paths": ["**/ui/**", "**/*Screen.kt", "**/compose/**"],
      "minimumAdditions": 20,
      "requiresNoSymbols": true,
      "severity": "info",
      "category": "review-load",
      "title": "{filename} user-facing surface changed",
      "evidence": "{additions} added lines may affect visible copy, controls, or layout."
    }
  ],
  "riskScoring": {
    "apiPaths": ["**/api/**", "**/network/**"],
    "sensitivePaths": ["**/*Auth*", "**/*Payment*", "**/*Security*", "**/*Permission*"]
  }
}

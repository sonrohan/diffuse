        "**/UI/**"
      ],
      "title" : "User-facing UI changes",
      "type" : "ui"
    }
  ],
  "displayName" : "Repo analysis profile",
  "fileClassifications" : [
    {
      "classification" : "generated",
      "paths" : [
        "**/*.generated.*",
        "**/*.generated.swift",
        "**/*.map",
        "**/*.min.js",
        "**/.next/**",
        "**/Cargo.lock",
        "**/DerivedData/**",
        "**/Gemfile.lock",
        "**/Generated/**",
        "**/build/**",
        "**/coverage/**",
        "**/dist/**",
        "**/generated/**",
        "**/go.sum",
        "**/package-lock.json",
        "**/pnpm-lock.yaml",
        "**/target/**",
        "**/yarn.lock"
      ]
    },
    {
      "classification" : "test",
      "paths" : [
        "**/*.spec.*",
        "**/*.test.*",
        "**/*Spec.*",
        "**/*Test.*",
        "**/*Tests.*",
        "**/*Tests.swift",
        "**/*UITests.swift",
        "**/*_test.*",
        "**/Tests/**",
        "**/UITests/**",
        "**/__tests__/**",
        "**/spec/**",
        "**/specs/**",
        "**/test/**",
        "**/tests/**"
      ]
    },
    {
      "classification" : "config",
      "paths" : [
        "**/*.config.*",
        "**/*.json",
        "**/*.properties",
        "**/*.toml",
        "**/*.xcconfig",
        "**/*.xcodeproj/**",
        "**/*.xcworkspace/**",
        "**/*.yaml",
        "**/*.yml",
        "**/*config.*",
        "**/Dockerfile",
        "**/docker-compose*.yml",
        ".*rc",
        ".*rc.*",
        ".env*",
        "Cartfile",
        "Dockerfile",
        "Package.swift",
        "Podfile"
      ]
    },
    {
      "classification" : "documentation",
      "paths" : [
        "**/*.md",
        "**/*.rst",
        "**/*.txt",
        "**/docs/**",
        "**/documentation/**"
      ]
    },
    {
      "classification" : "boilerplate",
      "paths" : [
        "**/*.d.ts",
        "**/fixtures/**",
        "**/snapshots/**",
        "**/third_party/**",
        "**/vendor/**"
      ]
    }
  ],
  "fileHighlights" : [
    {
      "category" : "review-load",
      "classifications" : [
        "source"
      ],
      "evidence" : "{additions} added lines may affect visible copy, controls, or layout.",
      "id" : "swift-large-visible-surface",
      "minimumAdditions" : 20,
      "paths" : [
        "**/*View.swift",
        "**/*Screen.swift",
        "**/Views/**",
        "**/Screens/**"
      ],
      "requiresNoSymbols" : true,
      "severity" : "info",
      "title" : "{filename} user-facing surface changed"
    }
  ],
  "id" : "repo",
  "riskScoring" : {
    "apiPathDelta" : 20,
    "apiPaths" : [
      "**/*API.swift",
      "**/Services/Services.swift",
      "chobi-core/src/main.rs"
    ],
    "architectureFindingDelta" : 20,
    "behaviorAddedDelta" : 10,
    "contractDelta" : 10,
    "generatedOnlyDelta" : -40,
    "highFanInDelta" : 10,
    "missingTestsDelta" : 20,
    "productionChangeDelta" : 10,
    "sensitivePathDelta" : 30,
    "sensitivePaths" : [
      "**/*Auth*",
      "**/*Keychain*",
      "**/*Security*",
      "**/Services/Services.swift",
      "**/Services/SwiftDataEntities.swift",
      "**/Services/AppState.swift"
    ],
    "testChangeDelta" : -15
  },
  "rules" : {
    "contractFindings" : [
      {
        "category" : "architecture",
        "id" : "contract/signature-changed",
        "message" : "Public API contract change: '{symbol}' signature modified. Verify all callers are compatible.",
        "metadataEquals" : {
          "contract_signature_changed" : "true"
        },
        "severity" : "medium"
      },
      {
        "category" : "architecture",
        "id" : "contract/return-type-changed",
        "message" : "Public API contract change: '{symbol}' return type changed. Verify callers and serialization boundaries.",
        "metadataEquals" : {
          "contract_return_type_changed" : "true"
        },
        "severity" : "medium"
      },
      {
        "category" : "architecture",
        "id" : "contract/new-public",
        "message" : "New public symbol '{symbol}' added to the API surface.",
        "metadataEquals" : {
          "contract_is_new_public" : "true"
        },
        "severity" : "low"
      }
    ],
    "importBoundaries" : [
      {
        "category" : "architecture",
        "forbiddenImports" : [
          "CoreData",
          "SwiftData",
          "SQLite*",
          "*Repository*",
          "*Persistence*"
        ],
        "id" : "architecture/swift-ui-import-boundary",
        "message" : "UI symbol '{symbol}' imports lower-level infrastructure. Keep presentation code behind configured app boundaries.",
        "severity" : "medium",
        "sourcePaths" : [
          "**/*View.swift",
          "**/Views/**",
          "**/Screens/**",
          "**/UI/**"
        ]
      }
    ],
    "missingTests" : {
      "enabled" : true,
      "message" : "Significant logic change ({additions} additions) without any matching test file additions or updates in this PR.",
      "minimumAdditions" : 10,
      "sourceClassifications" : [
        "source"
      ],
      "testClassifications" : [
        "test"
      ]
    },
    "schemaSync" : {
      "enabled" : false,
      "message" : "Schema migration detected without a corresponding configured schema or model change.",
      "migrationPaths" : [

      ],
      "schemaPaths" : [

      ]
    },
    "semanticAreaFindings" : [
      {
        "category" : "security",
        "id" : "security/auth-ast",
        "message" : "Auth symbol '{symbol}' modified. High regression risk - changes to authentication logic must be reviewed for correctness and side effects.",
        "semanticArea" : "security_authentication",
        "severity" : "high"
      },
      {
        "category" : "security",
        "id" : "security/crypto-ast",
        "message" : "Cryptographic symbol '{symbol}' modified. Encryption/signing changes carry high security risk.",
        "semanticArea" : "security_cryptography",
        "severity" : "high"
      },
      {
        "category" : "security",
        "id" : "security/payment-ast",
        "message" : "Payment symbol '{symbol}' modified. Validate billing flow correctness and test against edge cases.",
        "semanticArea" : "payment",
        "severity" : "medium"
      },
      {
        "category" : "security",
        "id" : "architecture/process-execution",
        "message" : "Method '{symbol}' in '{path}' executes an external process or shell command. Review for injection, privilege validation, and correctness.",
        "symbolNames" : [
          "run",
          "runGit",
          "checkoutPR",
          "sidecarURL",
          "manualCheckout"
        ],
        "severity" : "high"
      },
      {
        "category" : "architecture",
        "id" : "architecture/rust-core-change",
        "message" : "Rust analyzer core logic changed in '{symbol}'. Verify that AST parsing matches expected rules.",
        "paths" : [
          "chobi-core/**/*.rs"
        ],
        "severity" : "medium"
      }
    ],
    "symbolCoverage" : {
      "enabled" : true,
      "message" : "Risky production symbol '{symbol}' changed without a related test symbol update.",
      "riskMetadataEquals" : {
        "is_critical" : "true"
      },
      "riskMetadataPrefixes" : [
        "contract_"
      ],
      "riskMetadataSuffixes" : [
        "_added"
      ]
    }
  },
  "semanticHighlights" : [
    {
      "category" : "security",
      "evidence" : "AST-verified: '{symbol}' ({semanticType}) is an authentication entry point.",
      "id" : "security_authentication",

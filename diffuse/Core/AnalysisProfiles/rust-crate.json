{
  "version": 1,
  "id": "rust-crate",
  "displayName": "Rust crate",
  "extends": ["generic"],
  "fileClassifications": [
    {
      "classification": "test",
      "paths": ["**/tests/**", "**/*_test.rs"]
    },
    {
      "classification": "config",
      "paths": ["Cargo.toml", "Cargo.lock", "rust-toolchain*", "clippy.toml"]
    },
    {
      "classification": "generated",
      "paths": ["**/target/**"]
    }
  ],
  "buckets": [
    {
      "id": "api-contract",
      "type": "api-contract",
      "title": "Public API and crate surface",
      "paths": ["src/lib.rs", "**/api/**"]
    },
    {
      "id": "data",
      "type": "data",
      "title": "Data and persistence changes",
      "paths": ["**/db/**", "**/models/**", "**/migrations/**"]
    }
  ],
  "riskScoring": {
    "apiPaths": ["src/lib.rs", "**/api/**"],
    "sensitivePaths": ["**/*auth*", "**/*crypto*", "**/*security*", "**/*unsafe*"]
  }
}

{
  "version": 1,
  "id": "ios-swift",
  "displayName": "iOS / Swift",
  "extends": ["generic"],
  "fileClassifications": [
    {
      "classification": "test",
      "paths": ["**/*Tests.swift", "**/*UITests.swift", "**/Tests/**", "**/UITests/**"]
    },
    {
      "classification": "config",
      "paths": ["Package.swift", "Podfile", "Cartfile", "**/*.xcconfig", "**/*.xcodeproj/**", "**/*.xcworkspace/**"]
    },
    {
      "classification": "generated",
      "paths": ["**/DerivedData/**", "**/*.generated.swift", "**/Generated/**"]
    }
  ],
  "buckets": [
    {
      "id": "ui",
      "type": "ui",
      "title": "User-facing UI changes",
      "paths": ["**/*View.swift", "**/*Screen.swift", "**/Views/**", "**/Screens/**", "**/UI/**"]
    },
    {
      "id": "behavior",
      "type": "behavior",
      "title": "State and app behavior changes",
      "paths": ["**/*ViewModel.swift", "**/*Reducer.swift", "**/*Store.swift", "**/State/**"]
    },
    {
      "id": "data",
      "type": "data",
      "title": "Data model and persistence changes",
      "paths": ["**/*Model.swift", "**/Models/**", "**/Data/**", "**/Persistence/**", "**/*Repository.swift"]
    }
  ],
  "rules": {
    "importBoundaries": [
      {
        "id": "architecture/swift-ui-import-boundary",
        "sourcePaths": ["**/*View.swift", "**/Views/**", "**/Screens/**", "**/UI/**"],
        "forbiddenImports": ["CoreData", "SwiftData", "SQLite*", "*Repository*", "*Persistence*"],
        "severity": "medium",
        "category": "architecture",
        "message": "UI symbol '{symbol}' imports lower-level infrastructure. Keep presentation code behind configured app boundaries."
      }
    ]
  },
  "fileHighlights": [
    {
      "id": "swift-large-visible-surface",
      "classifications": ["source"],
      "paths": ["**/*View.swift", "**/*Screen.swift", "**/Views/**", "**/Screens/**"],
      "minimumAdditions": 20,
      "requiresNoSymbols": true,
      "severity": "info",
      "category": "review-load",
      "title": "{filename} user-facing surface changed",
      "evidence": "{additions} added lines may affect visible copy, controls, or layout."
    }
  ],
  "riskScoring": {
    "apiPaths": ["**/Sources/**/Public/**", "**/*API.swift"],
    "sensitivePaths": ["**/*Auth*", "**/*Payment*", "**/*Security*", "**/*Keychain*"]
  }
}

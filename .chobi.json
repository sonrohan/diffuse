    },
    {
      "id" : "behavior",
      "paths" : [
        "**/*ViewModel.swift",
        "**/*Reducer.swift",
        "**/*Store.swift",
        "**/State/**",
        "**/*State.swift",
        "**/*Engine.swift",
        "**/*Service.swift",
        "**/Services/Services.swift"
      ],
      "title" : "State and app behavior changes",

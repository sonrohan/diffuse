{
  "version": 1,
  "id": "go-service",
  "displayName": "Go service",
  "extends": ["generic"],
  "fileClassifications": [
    {
      "classification": "test",
      "paths": ["**/*_test.go"]
    },
    {
      "classification": "config",
      "paths": ["go.mod", "go.sum", "**/*.yaml", "**/*.yml", "**/*.toml"]
    }
  ],
  "buckets": [
    {
      "id": "api-contract",
      "type": "api-contract",
      "title": "API and handler changes",
      "paths": ["**/api/**", "**/handler/**", "**/handlers/**", "**/routes/**", "**/transport/**"]
    },
    {
      "id": "data",
      "type": "data",
      "title": "Data and persistence changes",
      "paths": ["**/db/**", "**/models/**", "**/repository/**", "**/repositories/**", "**/migrations/**"]
    }
  ],
  "rules": {
    "schemaSync": {
      "enabled": true,
      "migrationPaths": ["**/migrations/**", "**/*.sql"],
      "schemaPaths": ["**/models/**", "**/db/**"],
      "message": "Database migration detected, but no configured schema or model changes were found in this PR."
    }
  },
  "riskScoring": {
    "apiPaths": ["**/api/**", "**/handler/**", "**/handlers/**", "**/routes/**", "**/transport/**"],
    "sensitivePaths": ["**/*auth*", "**/*payment*", "**/*security*", "**/*permission*"]
  }
}

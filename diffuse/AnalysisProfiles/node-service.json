{
  "version": 1,
  "id": "node-service",
  "displayName": "Node service",
  "extends": ["generic"],
  "fileClassifications": [
    {
      "classification": "config",
      "paths": ["package.json", "tsconfig*.json", "eslint.config.*", "jest.config.*"]
    }
  ],
  "buckets": [
    {
      "id": "api-contract",
      "type": "api-contract",
      "title": "API and route changes",
      "paths": ["**/api/**", "**/routes/**", "**/controllers/**", "**/middleware/**"]
    },
    {
      "id": "data",
      "type": "data",
      "title": "Data and persistence changes",
      "paths": ["**/db/**", "**/models/**", "**/schema/**", "**/migrations/**", "**/repositories/**"]
    }
  ],
  "rules": {
    "schemaSync": {
      "enabled": true,
      "migrationPaths": ["**/migrations/**", "**/*.sql"],
      "schemaPaths": ["**/schema/**", "**/models/**", "**/db/**"],
      "message": "Database migration detected, but no configured schema or model changes were found in this PR."
    }
  },
  "riskScoring": {
    "apiPaths": ["**/api/**", "**/routes/**", "**/controllers/**", "**/middleware/**"],
    "sensitivePaths": ["**/*auth*", "**/*payment*", "**/*security*", "**/*session*"]
  }
}

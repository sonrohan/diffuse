{
  "version": 1,
  "id": "react-typescript",
  "displayName": "React / TypeScript",
  "extends": ["generic"],
  "fileClassifications": [
    {
      "classification": "test",
      "paths": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx", "**/__tests__/**"]
    },
    {
      "classification": "config",
      "paths": ["package.json", "tsconfig*.json", "vite.config.*", "next.config.*", "eslint.config.*", "tailwind.config.*"]
    },
    {
      "classification": "generated",
      "paths": ["**/.next/**", "**/dist/**", "**/build/**", "**/*.d.ts"]
    }
  ],
  "buckets": [
    {
      "id": "ui",
      "type": "ui",
      "title": "User-facing UI changes",
      "paths": ["**/components/**", "**/app/**", "**/pages/**", "**/*.tsx", "**/*.jsx"]
    },
    {
      "id": "api-contract",
      "type": "api-contract",
      "title": "API and route changes",
      "paths": ["**/api/**", "**/routes/**", "**/server/**"]
    },
    {
      "id": "data",
      "type": "data",
      "title": "Data and persistence changes",
      "paths": ["**/db/**", "**/models/**", "**/schema/**", "**/migrations/**"]
    }
  ],
  "rules": {
    "schemaSync": {
      "enabled": true,
      "migrationPaths": ["**/migrations/**", "**/*.sql"],
      "schemaPaths": ["**/schema/**", "**/models/**", "**/db/**"],
      "message": "Database migration detected, but no configured schema or model changes were found in this PR."
    },
    "importBoundaries": [
      {
        "id": "architecture/react-ui-import-boundary",
        "sourcePaths": ["**/components/**", "**/app/**", "**/pages/**", "**/*.tsx", "**/*.jsx"],
        "forbiddenImports": ["**/db*", "*database*", "*repository*", "*persistence*", "*prisma*"],
        "severity": "medium",
        "category": "architecture",
        "message": "UI symbol '{symbol}' imports lower-level infrastructure. Keep presentation code behind configured service boundaries."
      }
    ]
  },
  "fileHighlights": [
    {
      "id": "react-large-visible-surface",
      "classifications": ["source"],
      "paths": ["**/components/**", "**/app/**", "**/pages/**", "**/*.tsx", "**/*.jsx"],
      "minimumAdditions": 20,
      "requiresNoSymbols": true,
      "severity": "info",
      "category": "review-load",
      "title": "{filename} user-facing surface changed",
      "evidence": "{additions} added lines may affect visible copy, controls, or layout."
    }
  ],
  "riskScoring": {
    "apiPaths": ["**/api/**", "**/routes/**", "**/server/**"],
    "sensitivePaths": ["**/*auth*", "**/*payment*", "**/*security*", "**/*session*"]
  }
}
